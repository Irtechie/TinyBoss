<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TinyBoss.SettingsWindow"
        Title="TinyBoss Settings"
        Width="420" Height="360"
        CanResize="False"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/TinyBoss.ico">
  <StackPanel Margin="24" Spacing="16">

    <!-- Voice Hotkey -->
    <StackPanel Spacing="4">
      <TextBlock Text="Voice Push-to-Talk" FontWeight="SemiBold" />
      <ComboBox x:Name="VoiceHotkeyCombo" HorizontalAlignment="Stretch" />
    </StackPanel>

    <!-- Tile Hotkey -->
    <StackPanel Spacing="4">
      <TextBlock Text="Tile Overlay Hotkey" FontWeight="SemiBold" />
      <ComboBox x:Name="TileHotkeyCombo" HorizontalAlignment="Stretch" />
    </StackPanel>

    <!-- Microphone -->
    <StackPanel Spacing="4">
      <TextBlock Text="Microphone" FontWeight="SemiBold" />
      <ComboBox x:Name="MicCombo" HorizontalAlignment="Stretch" />
    </StackPanel>

    <!-- Conflict warning -->
    <TextBlock x:Name="ConflictWarning" Foreground="OrangeRed" FontSize="12"
               TextWrapping="Wrap" IsVisible="False" />

    <!-- Buttons -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
      <Button x:Name="SaveButton" Content="Save" Width="80" />
      <Button x:Name="CancelButton" Content="Cancel" Width="80" />
    </StackPanel>

  </StackPanel>
</Window>
