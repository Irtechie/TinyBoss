<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TinyBoss.SettingsWindow"
        Title="TinyBoss Settings"
        Width="420" Height="540"
        CanResize="False"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/TinyBoss.ico">
  <ScrollViewer>
  <StackPanel Margin="24" Spacing="16">

    <!-- Voice Hotkey -->
    <StackPanel Spacing="4">
      <TextBlock Text="Voice Push-to-Talk" FontWeight="SemiBold" />
      <ComboBox x:Name="VoiceHotkeyCombo" HorizontalAlignment="Stretch" />
    </StackPanel>

    <!-- Tile Hotkey -->
    <StackPanel Spacing="4">
      <TextBlock Text="Tile Overlay Hotkey (show/hide tiling grid)" FontWeight="SemiBold" />
      <ComboBox x:Name="TileHotkeyCombo" HorizontalAlignment="Stretch" />
    </StackPanel>

    <!-- Move Page Hotkey -->
    <StackPanel Spacing="4">
      <TextBlock Text="Move Page Modifier (hold while dragging a tiled CLI)" FontWeight="SemiBold" />
      <ComboBox x:Name="MovePageHotkeyCombo" HorizontalAlignment="Stretch" />
    </StackPanel>

    <!-- Microphone -->
    <StackPanel Spacing="4">
      <TextBlock Text="Microphone" FontWeight="SemiBold" />
      <ComboBox x:Name="MicCombo" HorizontalAlignment="Stretch" />
    </StackPanel>

    <!-- Monitors -->
    <StackPanel Spacing="4">
      <TextBlock Text="Tiling Monitors (uncheck to exclude)" FontWeight="SemiBold" />
      <StackPanel x:Name="MonitorList" Spacing="4" />
    </StackPanel>

    <!-- Snap Layout Override -->
    <StackPanel Spacing="4">
      <CheckBox x:Name="OverrideSnapCheck" Content="Replace Windows Snap Layouts with TinyBoss"
                ToolTip.Tip="Disables the Windows 11 snap flyout. Drag a terminal to show TinyBoss overlay instead." />
    </StackPanel>

    <!-- Grid Layout -->
    <StackPanel Spacing="4">
      <TextBlock Text="6-Pane Grid Layout" FontWeight="SemiBold" />
      <ComboBox x:Name="GridLayoutCombo" HorizontalAlignment="Stretch" />
    </StackPanel>

    <!-- Conflict warning -->
    <TextBlock x:Name="ConflictWarning" Foreground="OrangeRed" FontSize="12"
               TextWrapping="Wrap" IsVisible="False" />

    <!-- Buttons -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
      <Button x:Name="SaveButton" Content="Save" Width="80" />
      <Button x:Name="CancelButton" Content="Cancel" Width="80" />
    </StackPanel>

  </StackPanel>
  </ScrollViewer>
</Window>
